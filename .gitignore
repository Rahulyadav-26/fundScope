# Dependency directories (frontend & backend)
**/node_modules/

# Environment files – never commit credentials
*.env
*.env.*
# Explicit root env files (if any)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Next.js build artifacts (frontend)
**/.next/
out/

# Bundler / build output (both)
/dist/
/build/

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# OS‑generated files
.DS_Store
Thumbs.db

# IDE / editor configs
.vscode/
.idea/

# Test coverage reports
coverage/
